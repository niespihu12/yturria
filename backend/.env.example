# Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA hagas commit del archivo .env.

# ── Base de datos ─────────────────────────────────────────────────────────────
# MySQL:      mysql://user:password@localhost:3306/omnicanal
# PostgreSQL: postgresql://user:password@localhost:5432/omnicanal
DATABASE_URL=mysql://user:password@localhost:3306/omnicanal

# Habilita logging SQL de SQLAlchemy (útil en desarrollo, NO en producción).
# SQL_ECHO=false

# ── Autenticación ─────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REEMPLAZAR_CON_TOKEN_HEX_DE_64_CHARS

# Duración del token JWT en minutos (default: 1440 = 24 h).
# JWT_EXPIRE_MINUTES=1440

# Clave de cifrado para secretos de WhatsApp (access_token, auth_token, etc.).
# Si se omite, usa JWT_SECRET como fallback — se recomienda una clave dedicada.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
# TEXT_AGENTS_SECRET_KEY=REEMPLAZAR_CON_TOKEN_HEX_DE_64_CHARS

# ── Correo electrónico ────────────────────────────────────────────────────────
# Nombres canónicos (recomendados):
MAIL_USER=correo@dominio.com
MAIL_PASSWORD=REEMPLAZAR_CON_CONTRASENA_DE_APLICACION
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_FROM_NAME=Nombre Remitente
MAIL_FROM_EMAIL=correo@dominio.com

# Aliases alternativos (backward compat — usa solo uno de los dos grupos):
# SMTP_USER=correo@dominio.com
# SMTP_PASS=REEMPLAZAR
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# ── MFA ───────────────────────────────────────────────────────────────────────
MFA_MAX_ATTEMPTS=5
MFA_LOCK_MINUTES=10

# ── Proveedores de IA ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=REEMPLAZAR_CON_CLAVE_ELEVENLABS
OPENAI_API_KEY=REEMPLAZAR_CON_CLAVE_OPENAI
# GEMINI_API_KEY=REEMPLAZAR_CON_CLAVE_GEMINI

# ── Agentes de texto — comportamiento ─────────────────────────────────────────
# Si es "true", cada usuario debe ingresar su propia API Key de IA.
# TEXT_AGENTS_REQUIRE_USER_KEYS=false

# Timeout en segundos para llamadas a herramientas externas del agente.
# TEXT_TOOL_TIMEOUT_SECONDS=20

# Lista de hosts permitidos para herramientas externas (separados por coma).
# Vacío = sin restricción de host. Ej: api.ejemplo.com,otro.com
# TEXT_AGENT_TOOLS_ALLOWED_HOSTS=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública del frontend. Usada para CORS y para generar enlaces en notificaciones.
# Múltiples URLs separadas por coma para entornos multi-dominio.
FRONTEND_URL=http://localhost:5173

# URL pública alternativa del frontend (alias — usa FRONTEND_URL preferentemente).
# FRONTEND_PUBLIC_URL=https://app.tudominio.com

# ── Webhooks de voz ───────────────────────────────────────────────────────────
# Token de autenticación para el endpoint POST /api/webhooks/voice/tools/*.
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# VOICE_AGENT_TOOL_TOKEN=REEMPLAZAR_CON_TOKEN_SEGURO

# ── Google Calendar ───────────────────────────────────────────────────────────
# GOOGLE_CALENDAR_ENABLED=false

# Credenciales de cuenta de servicio (una de las dos formas):
# Opción A — JSON inline (recomendado para contenedores):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Opción B — ruta a archivo:
# GOOGLE_SERVICE_ACCOUNT_FILE=/ruta/al/service_account.json

# ID del calendario donde se crean las citas (default: "primary").
# GOOGLE_CALENDAR_ID=primary

# ── Perfil de tenant (opcional — defaults Yturria si se omiten) ───────────────
# TENANT_COMPANY_NAME=Yturria Agente de Seguros
# TENANT_COMPANY_YEARS=75
# TENANT_BUSINESS_HOURS=Lunes a viernes de 9:00 a 18:00 y sábados de 9:00 a 14:00 (hora CDMX)
# TENANT_CARRIERS=GNP, AXA, Chubb, MetLife, Bupa, Sura, Quálitas, Seguros Banorte, HDI, Zurich, Mapfre
# TENANT_LEGAL_NOTICE=              # Aviso legal antepuesto al primer mensaje de cada canal
# TENANT_COMPANY_CONTEXT=Especialistas en seguros de auto, vida, gastos médicos y empresariales en México
# TENANT_LEGAL_DISCLAIMER=          # Alias legacy de TENANT_LEGAL_NOTICE — usa el canónico arriba

# ── Scheduler de renovaciones ─────────────────────────────────────────────────
RENEWAL_REMINDER_DAYS_AHEAD=30

# ── Arranque ──────────────────────────────────────────────────────────────────
# Establecer en "true" SOLO en entorno de tests automatizados.
# SKIP_STARTUP_CHECK=false
